# App
APP_ENV=azure
APP_NAME=multi-agent-rag
LOG_LEVEL=INFO

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=your-search-index
AZURE_SEARCH_SEMANTIC_CONFIG=your-semantic-config

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Vector settings
VECTOR_DIMENSIONS=1024

# Retrieval/context settings
DEFAULT_TOP_K=10
MAX_CONTEXT_CHARS=50000
MAX_CHARS_PER_DOCUMENT=10000
MAX_REVISION_COUNT=1
MAX_SEARCH_PLANS=3
MAX_LLM_CALLS_PER_REQUEST=6
REQUEST_TIMEOUT_SECONDS=60

# Feature flags
ENABLE_TITLE_VECTOR_SEARCH=true
ENABLE_SEMANTIC_RANKER=true

# Azure Storage for eval outputs
AZURE_STORAGE_ACCOUNT=
EVAL_RESULTS_CONTAINER=eval-results

# Backend URL for Streamlit
BACKEND_BASE_URL=
